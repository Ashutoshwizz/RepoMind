# Server
PORT=4000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/repomind?retryWrites=true&w=majority

# OpenAI
OPENAI_API_KEY=sk-...

# Security
JWT_SECRET=your_jwt_secret_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Repo Storage (temp clone path)
REPO_STORAGE_PATH=/tmp/repomind-repos

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
